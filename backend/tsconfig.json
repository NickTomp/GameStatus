{
  "compilerOptions": {
    "target": "ES2020",
    "module": "nodenext",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,
    "moduleResolution": "nodenext",

    "typeRoots": [
      "./node_modules/@types",
      "./src/types"
    ]
  },

  "include": [
    "src"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}